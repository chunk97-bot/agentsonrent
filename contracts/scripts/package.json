{
  "name": "agentrent-escrow-scripts",
  "version": "1.0.0",
  "description": "Deployment and initialization scripts for AgentRent Escrow",
  "scripts": {
    "build": "cd .. && anchor build",
    "deploy:devnet": "cd .. && anchor deploy --provider.cluster devnet",
    "deploy:mainnet": "cd .. && anchor deploy --provider.cluster mainnet",
    "init:devnet": "NETWORK=devnet npx ts-node init-protocol.ts",
    "init:mainnet": "NETWORK=mainnet npx ts-node init-protocol.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.29.0",
    "@solana/web3.js": "^1.87.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
